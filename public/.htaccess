# Strato Apache Rewrite-Konfiguration für React SPA (Vite)
# Verhindert Redirect-Schleifen und liefert korrekte 200-Antworten für alle Routen

Options -MultiViews
RewriteEngine On

# Basis-URL setzen (Anpassen falls App in Unterverzeichnis liegt)
RewriteBase /

# Direkte Anfragen an existierende Dateien und Verzeichnisse durchlassen
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Fehlende -2000er Bildvarianten auf -1200er umleiten (Quellbilder nur 1200px)
RewriteRule ^images/buehne/(.+)-af-2000\.webp$ /images/buehne/$1-af-1200.webp [R=301,L]

# Alle anderen Anfragen auf index.html umleiten (SPA-Fallback)
# Kein Redirect (R-Flag fehlt bewusst) – internes Rewrite, keine Schleife
RewriteRule ^ index.html [L]

# Cache-Header für statische Assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
</IfModule>

# HTTPS erzwingen (kein www-Redirect, nur http -> https)
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]
