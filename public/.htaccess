# =====================================================
# Domain Canonicalization for paterbrown.com
# Redirect all variations to https://paterbrown.com
# =====================================================

RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Remove www (redirect www.paterbrown.com to paterbrown.com)
RewriteCond %{HTTP_HOST} ^www\.paterbrown\.com$ [NC]
RewriteRule ^(.*)$ https://paterbrown.com/$1 [L,R=301]


# =====================================================
# Performance & Caching
# =====================================================

# Enable GZIP compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# Enable Brotli compression (if mod_brotli is available)
<IfModule mod_brotli.c>
    AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# Browser caching
<IfModule mod_expires.c>
    ExpiresActive On
    
    # Images
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    
    # Fonts
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
    
    # CSS & JavaScript
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"
    
    # HTML
    ExpiresByType text/html "access plus 1 hour"
</IfModule>

# =====================================================
# Security Headers
# =====================================================

<IfModule mod_headers.c>
    # Hide server version (security)
    Header unset Server
    Header always unset Server

    # Prevent MIME type sniffing
    Header always set X-Content-Type-Options "nosniff"

    # Clickjacking protection
    Header always set X-Frame-Options "SAMEORIGIN"

    # XSS protection
    Header always set X-XSS-Protection "1; mode=block"

    # Referrer Policy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # HSTS – Browser soll nur HTTPS verwenden (1 Jahr)
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS

    # Permissions Policy (replaces Feature-Policy)
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=()"

    # Content Security Policy
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cmp.osano.com https://www.googletagmanager.com https://www.google-analytics.com https://www.clarity.ms https://sibforms.com; style-src 'self' 'unsafe-inline' https://sibforms.com https://fonts.googleapis.com; img-src 'self' data: blob: https: http:; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://*.supabase.co https://*.google-analytics.com https://*.clarity.ms https://cmp.osano.com https://sibforms.com; frame-src 'self' https://cmp.osano.com; object-src 'none'; base-uri 'self'"
</IfModule>

# =====================================================
# Pre-rendered Pages + SPA Fallback
# =====================================================

# Prevent Apache from adding trailing slash to directories (avoids 301 redirects)
DirectorySlash Off

<IfModule mod_rewrite.c>
    RewriteBase /

    # If URL is a directory without trailing slash and has an index.html, serve it directly
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteCond %{REQUEST_FILENAME}/index.html -f
    RewriteRule ^(.+?)/?$ $1/index.html [L]

    # Don't rewrite actual files or directories
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Non-existing static assets → 404 (prevents SPA fallback serving HTML for missing images)
    RewriteRule \.(webp|jpg|jpeg|png|gif|svg|ico|woff2|woff|ttf|eot|css|js|map|mp4|webm|pdf)$ - [R=404,L]

    # SPA Fallback: everything else to index.html
    RewriteRule ^ index.html [L]
</IfModule>
